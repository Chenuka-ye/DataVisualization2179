{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 350,
  "title": "Global Bean Price vs Australian Spending",
  "layer": [
    {
      "data": { "url": "datasets/Cafes, restaurants and takeaway food services.csv" },
      "transform": [
        { "calculate": "timeParse(datum.Month, '%b-%Y')", "as": "date" },
        { "filter": "datum.date != null" },
        { "calculate": "toNumber(replace(datum['Seasonally adjusted ($m)'], ',', ''))", "as": "spending" }
      ],
      "mark": {"type": "area", "color": "#e0e0e0", "opacity": 0.5},
      "encoding": {
        "x": {"field": "date", "type": "temporal", "title": "Year"},
        "y": {"field": "spending", "type": "quantitative", "title": "Australian Spending ($M)"}
      }
    },
    {
      "data": { "url": "datasets/coffee-prices-historical-data.csv" },
      "transform": [{ "calculate": "toDate(datum.date)", "as": "date" }],
      "mark": {"type": "line", "color": "#5d4037", "strokeWidth": 2},
      "encoding": {
        "x": {"field": "date", "type": "temporal"},
        "y": {"field": " value", "type": "quantitative", "title": "Global Coffee Price (USD/lb)"}
      }
    }
  ],
  "resolve": {"scale": {"y": "independent"}},
  "config": { "font": "Arial", "axis": {"labelFontSize": 12, "titleFontSize": 14}, "title": {"fontSize": 16, "anchor": "start"} }
}
