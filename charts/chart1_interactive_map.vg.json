{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": { "url": "datasets/cafes-and-restaurants-with-seating-capacity.csv" },
  "vconcat": [
    {
      "width": "container",
      "height": 350,
      "title": "Interactive Map: Melbourne Cafe Locations",
      "projection": { "type": "mercator", "center": [144.963, -37.814], "scale": 200000 },
      "layer": [
        {
          "data": { "url": "datasets/melbourne_suburbs.topojson", "format": {"type": "topojson", "feature": "melbourne_suburbs"} },
          "mark": {"type": "geoshape", "fill": "#EAE2D6", "stroke": "white"}
        },
        {
          "mark": { "type": "circle", "tooltip": true, "opacity": 0.7, "stroke": "white" },
          "encoding": {
            "longitude": { "field": "longitude", "type": "quantitative" },
            "latitude": { "field": "latitude", "type": "quantitative" },
            "size": { "field": "number_of_seats", "type": "quantitative", "scale": {"range": [10, 180]} },
            "color": { "condition": { "param": "area_select", "field": "clue_small_area", "type": "nominal", "legend": null, "scale": {"scheme": "browns"} }, "value": "transparent" },
            "tooltip": [
              { "field": "trading_name", "title": "Café Name" },
              { "field": "clue_small_area", "title": "Area" },
              { "field": "number_of_seats", "title": "Total Seats" }
            ]
          }
        }
      ]
    },
    {
      "width": "container",
      "height": 100,
      "title": "Top Areas (Click a bar to filter the map)",
      "params": [{ "name": "area_select", "select": {"type": "point", "fields": ["clue_small_area"]} }],
      "mark": "bar",
      "encoding": {
        "x": { "aggregate": "sum", "field": "number_of_seats", "type": "quantitative", "title": "Total Seats" },
        "y": { "field": "clue_small_area", "type": "nominal", "sort": "-x", "title": "Area" },
        "color": { "condition": { "param": "area_select", "value": "#5D4037" }, "value": "#D7CCC8" }
      }
    }
  ]
}
