{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 350,
  "title": "Growth of Cafe Seating (2006 - 2014)",
  "data": { "url": "datasets/CafeResturantSeating.csv" },
  "transform": [
    { "fold": ["Indoor Seating", "Outdoor Seating"], "as": ["Seating Type", "Seats"] },
    { "filter": "datum.Seats != null && datum.Seats != 'NULL'" },
    { "calculate": "toNumber(datum.Seats)", "as": "Seats" }
  ],
  "mark": { "type": "line", "point": true, "strokeWidth": 3 },
  "encoding": {
    "x": { "field": "Survey Year", "type": "ordinal", "title": "Survey Year" },
    "y": { "aggregate": "sum", "field": "Seats", "type": "quantitative", "title": "Total Seats" },
    "color": { "field": "Seating Type", "type": "nominal", "scale": {"range": ["#5d4037", "#a1887f"]} },
    "tooltip": [{"field": "Survey Year"}, {"field": "Seating Type"}, {"aggregate": "sum", "field": "Seats", "title": "Total Seats"}]
  },
  "config": { "font": "Arial", "axis": {"labelFontSize": 12, "titleFontSize": 14}, "title": {"fontSize": 16, "anchor": "start"} }
}
